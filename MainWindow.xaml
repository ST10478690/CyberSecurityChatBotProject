<Window x:Class="CyberSecurityChatBotGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Height="600"
        Width="900"
        Background="#1E1E1E">

    <Grid>

        <!-- TITLE -->
        <TextBlock Text="CYBERSECURITY AWARENESS BOT"
                   Foreground="HotPink"
                   FontSize="28"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,20,0,0"/>

        <!-- CHAT DISPLAY -->
        <TextBox x:Name="ChatDisplay"
                 Margin="30,80,30,150"
                 Background="Black"
                 Foreground="White"
                 FontSize="16"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 VerticalScrollBarVisibility="Auto"/>

        <!-- USER INPUT -->
        <TextBox x:Name="UserInput"
                 Height="40"
                 Margin="30,0,160,50"
                 VerticalAlignment="Bottom"
                 FontSize="16"
                 Foreground="Black"/>

        <!-- SEND BUTTON -->
        <Button Content="SEND"
                Width="100"
                Height="40"
                Margin="0,0,30,50"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Background="HotPink"
                Foreground="White"
                FontWeight="Bold"
                Click="SendButton_Click"/>

    </Grid>
</Window>